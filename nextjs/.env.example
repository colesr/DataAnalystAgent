# ============================================================
# Postgres — auto-injected by Railway when you add the plugin
# Local dev: install Postgres or use a free Neon/Supabase instance
# ============================================================
DATABASE_URL=postgres://user:pass@localhost:5432/digital_analyst

# ============================================================
# NextAuth (Auth.js v5)
# Generate a secret with: openssl rand -base64 32
# In Railway, set AUTH_URL to your deployed URL
# ============================================================
AUTH_SECRET=replace_me_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# Google OAuth — create credentials at console.cloud.google.com
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ============================================================
# AI providers (server-side keys — users no longer need to BYOK)
# Both optional. If both set, the model picker will work for both.
# ============================================================
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ============================================================
# Optional: allow BYOK fallback so unauthenticated visitors
# can still use the app with their own keys
# ============================================================
ALLOW_BYOK=true
