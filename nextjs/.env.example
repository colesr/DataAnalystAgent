# ============================================================
# Postgres — use Neon's free tier: https://neon.tech
# Use the DIRECT connection string (NOT the pooled one) so the
# agent's transactional `SET LOCAL` queries work correctly.
# Format: postgres://USER:PASS@ep-xxxx.REGION.neon.tech/DB?sslmode=require
# ============================================================
DATABASE_URL=postgres://user:pass@localhost:5432/digital_coworker

# ============================================================
# NextAuth (Auth.js v5)
# Required even for anonymous-only deployments.
# Generate with: openssl rand -base64 32
# Vercel sets the URL automatically — no need for AUTH_URL.
# ============================================================
AUTH_SECRET=replace_me_with_openssl_rand_base64_32

# Google OAuth (optional). Without these the app stays in anonymous mode.
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ============================================================
# AI providers — OPTIONAL after Phase 15b.
#
# Local mode (default): the in-browser WebLLM engine handles inference.
# No keys required, free forever, runs on the user's GPU.
#
# Set these only if you want the legacy "cloud" model picker entries
# (Claude / Gemini) to work. They use server-side keys.
# ============================================================
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ============================================================
# Cron secret — protects /api/schedules/run and /api/alerts/check.
# Set the same value in your GitHub Actions repo secrets so the
# scheduled workflow can call them. Required if you keep schedules/alerts.
# ============================================================
CRON_SECRET=

# ============================================================
# Email alerts via Resend (optional). Without these, alert triggers
# are still logged + can fire to Slack via per-alert webhooks.
# ============================================================
RESEND_API_KEY=
RESEND_FROM=

# Comma-separated list of signed-in emails that can view /admin
ADMIN_EMAILS=
